# --- Solana NFT Marketplace (Devnet) ---
# Copy to `.env` and adjust. NEVER commit a real `.env` with secrets.
# All vars are build-time public values (no private keys here).

# RPC endpoint. Default devnet works but is rate-limited; use a Helius/QuickNode
# devnet URL for reliable WebSocket account subscriptions.
VITE_RPC_URL=https://api.devnet.solana.com

# Optional dedicated WebSocket endpoint. If unset, the RPC URL is reused
# (http -> ws is derived automatically).
VITE_RPC_WS_URL=

# Anchor program ID for the marketplace. This is the SINGLE source of truth:
# the client overrides the bundled IDL's address with it, so both the
# instructions and the PDA derivations target this exact program. The default
# below is the LIVE Devnet deployment (initialized as "devnet-marketplace") —
# if you redeploy your own, set this to the new address and restart.
VITE_PROGRAM_ID=Bx1csW3DusPh3Lcij7VMBiGtwhwRBRoobjyZneWGqbM7

# Solana cluster. The UI forces Devnet and warns on mismatch.
VITE_NETWORK=devnet

# Human-readable marketplace name used as a PDA seed (must match the on-chain config).
VITE_MARKETPLACE_NAME=devnet-marketplace

# Optional: URL of a serverless endpoint that proxies to Claude for the AI-assist
# features (name/description generation). Keeps your API key server-side. If
# unset, AI-assist uses a local, no-key heuristic generator.
VITE_AI_PROXY_URL=
